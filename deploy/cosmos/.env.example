# Image published by this fork on GHCR.
RIVEN_IMAGE=ghcr.io/example/riven-orchestrator:main

PUID=1000
PGID=1000
TZ=America/Sao_Paulo

RIVEN_PORT=8080
JELLYFIN_PORT=8096
SEERR_PORT=5055
PROWLARR_PORT=9696
ZILEAN_PORT=8181

RIVEN_ORIGIN=http://SERVER_IP:8080
SETTINGS_FILENAME=settings.json
API_KEY=
RIVEN_DEBUG=INFO

RIVEN_FILESYSTEM_MOUNT_PATH=/mount
RIVEN_LIBRARY_PATH=/mount

RIVEN_DOWNLOADERS_REAL_DEBRID_ENABLED=false
RIVEN_DOWNLOADERS_REAL_DEBRID_API_KEY=

RIVEN_JELLYFIN_ENABLED=false
RIVEN_JELLYFIN_URL=http://jellyfin:8096
RIVEN_JELLYFIN_API_KEY=

RIVEN_CONTENT_OVERSEERR_ENABLED=false
RIVEN_CONTENT_OVERSEERR_URL=http://seerr:5055
RIVEN_CONTENT_OVERSEERR_API_KEY=
RIVEN_CONTENT_OVERSEERR_USE_WEBHOOK=false
RIVEN_CONTENT_OVERSEERR_SYNC_STATUS=true

RIVEN_SCRAPING_PROWLARR_ENABLED=false
RIVEN_SCRAPING_PROWLARR_URL=http://prowlarr:9696
RIVEN_SCRAPING_PROWLARR_API_KEY=
RIVEN_SCRAPING_PROWLARR_USE_ALIASES=true
RIVEN_SCRAPING_PROWLARR_MAX_QUERY_VARIANTS=3
RIVEN_SCRAPING_PROWLARR_PREFERRED_ALIAS_COUNTRIES=us,jp,br,pt

RIVEN_SCRAPING_ZILEAN_ENABLED=false
RIVEN_SCRAPING_ZILEAN_URL=http://zilean:8181

RIVEN_SCRAPING_TORRENTIO_ENABLED=false
RIVEN_SCRAPING_TORRENTIO_URL=http://torrentio.strem.fun

RIVEN_DATA_DIR=./data/riven
RIVEN_DB_DIR=./data/postgres
RIVEN_MOUNT_DIR=./mount
JELLYFIN_CONFIG_DIR=./data/jellyfin/config
JELLYFIN_CACHE_DIR=./data/jellyfin/cache
SEERR_CONFIG_DIR=./data/seerr
PROWLARR_CONFIG_DIR=./data/prowlarr
ZILEAN_DATA_DIR=./data/zilean

RIVEN_POSTGRES_USER=postgres
RIVEN_POSTGRES_PASSWORD=change-me-riven
RIVEN_POSTGRES_DB=riven

ZILEAN_POSTGRES_DB=zilean

SEERR_LOG_LEVEL=info
STACK_NETWORK_NAME=riven-media
