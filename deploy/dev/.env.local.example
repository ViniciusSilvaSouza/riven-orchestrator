# Copie os valores abaixo para o .env raiz quando for testar a stack local.
# O compose local ja injeta os hostnames internos dos servicos.
# O frontend local usa a mesma API key fixa do compose.

# Debrid
RIVEN_DOWNLOADERS_REAL_DEBRID_ENABLED=true
API_KEY=0123456789abcdef0123456789abcdef
RIVEN_DOWNLOADERS_REAL_DEBRID_API_KEY=cole_sua_api_key_aqui

# Servicos auxiliares: deixe false ate pegar as API keys da UI de cada um.
RIVEN_JELLYFIN_ENABLED=true
RIVEN_JELLYFIN_API_KEY=cole_a_api_key_do_jellyfin_aqui

RIVEN_CONTENT_OVERSEERR_ENABLED=true
RIVEN_CONTENT_OVERSEERR_API_KEY=cole_a_api_key_do_overseerr_aqui
RIVEN_CONTENT_OVERSEERR_USE_WEBHOOK=false

RIVEN_SCRAPING_PROWLARR_ENABLED=true
RIVEN_SCRAPING_PROWLARR_API_KEY=cole_a_api_key_do_prowlarr_aqui

RIVEN_SCRAPING_ZILEAN_ENABLED=true

RIVEN_SCRAPING_COMET_ENABLED=true

# Opcional para testar coleta via Trakt
RIVEN_CONTENT_TRAKT_ENABLED=false
RIVEN_CONTENT_TRAKT_API_KEY=
